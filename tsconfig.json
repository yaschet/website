{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "Next.js",
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker", "ScriptHost"],
		"module": "ESNext",
		"esModuleInterop": true,
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": false,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"noImplicitAny": true,
		"allowJs": false,
		"forceConsistentCasingInFileNames": true,
		"incremental": true,
		"tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*", "./src/*"],
			"@src/*": ["./src/*"],
			"@/types/*": ["./src/types/*"],
			"@actions/*": ["./src/actions/*"],
			"@app/*": ["./src/app/*"],
			"@components/*": ["./src/components/*"],
			"@hooks/*": ["./src/hooks/*"],
			"@library/*": ["./src/library/*"],
			"@schemas/*": ["./src/schemas/*"],
			"@services/*": ["./src/services/*"],
			"@stores/*": ["./src/stores/*"],
			"@utils/*": ["./src/utils/*"],
			"@ui/*": ["./src/components/ui/*"],
			"@public/*": ["public/*"],
			"@queries/*": ["./src/queries/*"]
		},
		"plugins": [
			{
				"name": "next"
			}
		],
		"skipLibCheck": true
	},
	"ts-node": {
		"compilerOptions": {
			"module": "ESNext",
			"moduleResolution": "Node"
		}
	},
	"include": [
		"./*",
		"src/env.ts",
		"src/*",
		"src/**/*",
		"src/**/*.{js,jsx,ts,tsx,mts,mjs,cjs,cts,d.ts,js.flow}",
		"next/types/**/*.ts",
		"next-env.d.ts",
		"next.config.js",
		"eslint.config.js",
		"dist/types/**/*.ts",
		".storybook/*",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": [
		"./node_modules",
		"./.next",
		"./.storybook",
		"./dist",
		"./.git",
		"./.github",
		"../.vscode",
		"./.husky",
		"./swc",
		"./coverage",
		"./public",
		"./analyze"
	]
}
